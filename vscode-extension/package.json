{
  "name": "unreal-scala-lsp",
  "displayName": "Unreal Scala LSP",
  "description": "Source-only Scala language server",
  "version": "0.1.0",
  "publisher": "nguyenyou",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/nguyenyou/unreal-scala-lsp"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:scala"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Unreal Scala LSP",
      "properties": {
        "unrealScalaLsp.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the unreal-scala-lsp native binary or assembly jar"
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/vscode": "1.110.0",
    "@vscode/vsce": "3.7.1",
    "typescript": "6.0.2"
  },
  "scripts": {
    "compile": "tsc -p .",
    "package": "vsce package"
  }
}

{
  "name": "unreal-scala-lsp",
  "displayName": "Unreal Scala LSP",
  "description": "Instant Scala navigation for the AI era — go-to-definition and find-references in ~10ms, no compiler or build server needed",
  "version": "1.3.0",
  "publisher": "nguyenyou",
  "license": "MIT",
  "icon": "unreal-logo.png",
  "repository": {
    "url": "https://github.com/nguyenyou/unreal-scala-lsp"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:scala",
    "onLanguage:java"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Unreal Scala LSP",
      "properties": {
        "unrealScalaLsp.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the unreal-scala-lsp native binary or assembly jar"
        },
        "unrealScalaLsp.compilerPrecise": {
          "type": "boolean",
          "default": false,
          "description": "Use compiler-precise mode with presentation compiler for full semantic analysis (experimental)"
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/vscode": "1.110.0",
    "@vscode/vsce": "3.7.1",
    "esbuild": "0.27.4",
    "typescript": "6.0.2"
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "check": "tsc -p . --noEmit",
    "package": "vsce package"
  }
}

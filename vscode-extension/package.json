{
  "name": "mini-scala-lsp",
  "displayName": "Mini Scala LSP",
  "description": "Minimal Scala language server",
  "version": "0.1.0",
  "publisher": "tunguyen",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:scala"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Mini Scala LSP",
      "properties": {
        "miniScalaLsp.serverJar": {
          "type": "string",
          "default": "",
          "description": "Path to the mini-scala-lsp server assembly jar"
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/vscode": "1.110.0",
    "@vscode/vsce": "3.7.1",
    "typescript": "6.0.2"
  },
  "scripts": {
    "compile": "tsc -p .",
    "package": "vsce package"
  }
}

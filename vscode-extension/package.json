{
  "name": "mini-scala-lsp",
  "displayName": "Mini Scala LSP",
  "description": "Minimal Scala language server with Go to Definition",
  "version": "0.1.0",
  "publisher": "tunguyen",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:scala"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Mini Scala LSP",
      "properties": {
        "miniScalaLsp.serverJar": {
          "type": "string",
          "default": "",
          "description": "Path to the mini-scala-lsp server assembly jar"
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  },
  "scripts": {
    "compile": "tsc -p .",
    "package": "vsce package"
  }
}
